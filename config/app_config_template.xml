<?xml version="1.0" encoding="UTF-8"?>
<!--
  langchain.cpp Application Configuration Template

  Every functional module has its own top-level tag under <config>.
  Each module supports an <enabled> switch so features can be toggled
  individually without removing the block.

  The <llm> block supports multiple <source> children for multi-provider
  failover or routing.  Add as many sources as needed.

  Rules:
    - Root element must be <config>.
    - Each top-level child under <config> is a section; the tag name is the section name.
    - Section child element names become keys; their text content becomes values.
    - All values are stored as strings and converted on read via ConfigSection::get<T>().
-->
<config>

  <!-- ================================================================ -->
  <!--  Application                                                     -->
  <!-- ================================================================ -->
  <app>
    <enabled>true</enabled>
    <name>langchain_app</name>
    <version>1.0.0</version>
    <log_level>info</log_level>
    <log_dir></log_dir>
    <worker_threads>4</worker_threads>
  </app>

  <!-- ================================================================ -->
  <!--  LLM Providers (multi-source)                                    -->
  <!-- ================================================================ -->
  <llm>
    <enabled>true</enabled>
    <default_source>primary</default_source>

    <source>
      <id>primary</id>
      <provider>openai</provider>
      <base_url>https://api.openai.com/v1</base_url>
      <api_key>${OPENAI_API_KEY}</api_key>
      <model>gpt-4o</model>
      <temperature>0.7</temperature>
      <max_tokens>4096</max_tokens>
      <top_p>0.95</top_p>
      <top_k>50</top_k>
      <timeout_seconds>30</timeout_seconds>
    </source>

    <source>
      <id>fallback</id>
      <provider>deepseek</provider>
      <base_url>https://api.deepseek.com</base_url>
      <api_key>${DEEPSEEK_API_KEY}</api_key>
      <model>deepseek-chat</model>
      <temperature>0.7</temperature>
      <max_tokens>4096</max_tokens>
      <top_p>0.95</top_p>
      <top_k>50</top_k>
      <timeout_seconds>30</timeout_seconds>
    </source>

    <source>
      <id>local</id>
      <provider>ollama</provider>
      <base_url>http://localhost:11434</base_url>
      <api_key></api_key>
      <model>llama3.2</model>
      <temperature>0.7</temperature>
      <max_tokens>4096</max_tokens>
      <top_p>0.95</top_p>
      <top_k>50</top_k>
      <timeout_seconds>300</timeout_seconds>
    </source>
  </llm>

  <!-- ================================================================ -->
  <!--  Embedding                                                       -->
  <!-- ================================================================ -->
  <embedding>
    <enabled>true</enabled>
    <provider>openai</provider>
    <model>text-embedding-3-small</model>
    <dimensions>1536</dimensions>
    <batch_size>16</batch_size>
  </embedding>

  <!-- ================================================================ -->
  <!--  Vector Store                                                    -->
  <!-- ================================================================ -->
  <vectorstore>
    <enabled>true</enabled>
    <backend>sqlite</backend>
    <db_path>./data/vectorstore.db</db_path>
    <table_name>embeddings</table_name>
  </vectorstore>

  <!-- ================================================================ -->
  <!--  API Server                                                      -->
  <!-- ================================================================ -->
  <api_server>
    <enabled>true</enabled>
    <host>0.0.0.0</host>
    <port>8080</port>
    <api_key></api_key>
    <enable_cors>true</enable_cors>
    <max_request_body_mb>10</max_request_body_mb>
    <read_timeout_sec>120</read_timeout_sec>
    <write_timeout_sec>120</write_timeout_sec>
  </api_server>

  <!-- ================================================================ -->
  <!--  Memory / Conversation                                           -->
  <!-- ================================================================ -->
  <memory>
    <enabled>true</enabled>
    <backend>sqlite</backend>
    <db_path>./data/memory.db</db_path>
    <max_history_turns>20</max_history_turns>
    <summarize_threshold>40</summarize_threshold>
  </memory>

  <!-- ================================================================ -->
  <!--  RAG (Retrieval-Augmented Generation)                            -->
  <!-- ================================================================ -->
  <rag>
    <enabled>true</enabled>
    <retriever_top_k>5</retriever_top_k>
    <score_threshold>0.75</score_threshold>
    <chunk_size>500</chunk_size>
    <chunk_overlap>50</chunk_overlap>
  </rag>

  <!-- ================================================================ -->
  <!--  Agent                                                           -->
  <!-- ================================================================ -->
  <agent>
    <enabled>true</enabled>
    <type>react</type>
    <max_iterations>10</max_iterations>
    <system_prompt>You are a helpful assistant with access to tools.</system_prompt>
    <temperature>0.7</temperature>
    <max_tokens>4096</max_tokens>
    <top_p>0.95</top_p>
    <top_k>50</top_k>
  </agent>

  <!-- ================================================================ -->
  <!--  A2A (Agent-to-Agent)                                            -->
  <!-- ================================================================ -->
  <a2a>
    <enabled>false</enabled>
    <agent_id>agent_001</agent_id>
    <agent_name>Default Agent</agent_name>
    <discovery_url></discovery_url>
    <heartbeat_interval_sec>60</heartbeat_interval_sec>
  </a2a>

  <!-- ================================================================ -->
  <!--  MCP (Model Context Protocol)                                    -->
  <!-- ================================================================ -->
  <mcp>
    <enabled>false</enabled>
    <server_url></server_url>
    <timeout_seconds>30</timeout_seconds>
  </mcp>

  <!-- ================================================================ -->
  <!--  Document Loader                                                 -->
  <!-- ================================================================ -->
  <document>
    <enabled>true</enabled>
    <max_file_size_mb>50</max_file_size_mb>
    <supported_extensions>txt,md,pdf,docx</supported_extensions>
  </document>

  <!-- ================================================================ -->
  <!--  Text Splitter                                                   -->
  <!-- ================================================================ -->
  <text_splitter>
    <enabled>true</enabled>
    <chunk_size>500</chunk_size>
    <chunk_overlap>50</chunk_overlap>
    <separator>\n\n</separator>
  </text_splitter>

  <!-- ================================================================ -->
  <!--  Tools                                                           -->
  <!-- ================================================================ -->
  <tool>
    <enabled>true</enabled>
    <timeout_seconds>30</timeout_seconds>

    <!-- Each <item> registers one C++ implemented tool by name.
         The framework looks up the name in the built-in registry. -->
    <item>
      <name>calculator</name>
      <enabled>true</enabled>
    </item>
    <item>
      <name>web_search</name>
      <enabled>false</enabled>
    </item>
    <item>
      <name>file_reader</name>
      <enabled>true</enabled>
    </item>
  </tool>

  <!-- ================================================================ -->
  <!--  Skills                                                          -->
  <!-- ================================================================ -->
  <skill>
    <enabled>true</enabled>
    <skills_dir>./skills</skills_dir>
    <auto_reload>false</auto_reload>
  </skill>

  <!-- ================================================================ -->
  <!--  Hooks / Observability                                           -->
  <!-- ================================================================ -->
  <hooks>
    <enabled>true</enabled>
    <log_to_stderr>true</log_to_stderr>
    <log_to_file>false</log_to_file>
    <log_file_path>./logs/hooks.log</log_file_path>
  </hooks>

</config>
